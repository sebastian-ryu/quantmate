# App
# 앱 실행 환경 이름이다. 로컬 개발은 local을 사용한다.
APP_ENV=local
# FastAPI 백엔드가 바인딩할 호스트다. 로컬 PC에서만 쓰려면 127.0.0.1을 유지한다.
APP_HOST=127.0.0.1
# FastAPI 백엔드 포트다. 프론트의 PUBLIC_API_BASE_URL과 맞아야 한다.
APP_PORT=8000
# 사용자 입력, 화면 표시, DB 저장 기준 시간대다. 한국 주식 기준으로 Asia/Seoul을 사용한다.
APP_TIMEZONE=Asia/Seoul
# 세션/서명 등에 사용할 앱 비밀키다. 운영 환경에서는 반드시 임의의 긴 값으로 바꾼다.
APP_SECRET_KEY=change-me
# 브라우저에서 백엔드 API 호출을 허용할 프론트엔드 주소 목록이다.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Web client
# SvelteKit 프론트엔드가 호출할 백엔드 API 주소다.
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# true면 전략 화면에서 KIS 모의투자 계좌/주문 제안/모의 일괄 주문 UI를 표시한다.
PUBLIC_SHOW_PAPER_TRADING_UI=false
# 운영 Docker 배포에서 외부에 노출할 프론트엔드 포트다.
FRONTEND_PORT=5173
# 운영 Docker 배포에서 외부에 노출할 백엔드 포트다.
BACKEND_PORT=8000

# Database
# Docker MySQL 컨테이너에 접속할 호스트다.
MYSQL_HOST=127.0.0.1
# 로컬 PC에 노출할 MySQL 포트다. 이미 사용 중이면 다른 포트로 바꾼다.
MYSQL_PORT=3306
# 운영 Docker 배포에서 NAS 내부망에 노출할 MySQL 포트다. GUI 클라이언트 접속용이며 Synology 방화벽으로 허용 IP를 제한한다.
MYSQL_PUBLIC_PORT=3306
# QuantMate가 사용할 MySQL 데이터베이스 이름이다.
MYSQL_DATABASE=quantmate
# QuantMate가 DB 접속에 사용할 MySQL 사용자 이름이다.
MYSQL_USER=quantmate
# QuantMate DB 사용자의 비밀번호다. 운영 환경에서는 반드시 바꾼다.
MYSQL_PASSWORD=change-me
# MySQL root 계정 비밀번호다. 운영 환경에서는 반드시 바꾼다.
MYSQL_ROOT_PASSWORD=change-root-me
# SQLAlchemy가 사용할 DB 접속 문자열이다. 위 MYSQL_* 값과 일치해야 한다.
DATABASE_URL=mysql+pymysql://quantmate:change-me@127.0.0.1:3306/quantmate
# 운영 Docker 배포에서 MySQL 데이터를 저장할 NAS 경로다.
QM_MYSQL_DATA_PATH=./runtime/mysql
# InnoDB 버퍼 풀 크기(docker-compose.prod.yml). 기본 128MB로는 대용량 daily_prices가 안 담겨
# NAS HDD 반복 읽기가 발생한다. NAS RAM 여유에 맞춰 설정하고 변경 후 mysql 컨테이너를 재생성한다.
# 2GB NAS: 384M(권장) / 4GB: 1G / 6GB: 2G. 너무 크게 잡으면 컨테이너 OOM 위험.
MYSQL_INNODB_BUFFER_POOL_SIZE=384M
# 운영 Docker 배포에서 KIS/OpenDART 토큰과 캐시를 저장할 NAS 경로다.
QM_BACKEND_RUNTIME_PATH=./runtime/backend
# 운영 Docker 배포에서 백엔드 로그를 저장할 NAS 경로다.
QM_BACKEND_LOG_PATH=./runtime/logs/backend

# Korea Investment & Securities Open API
# 한국투자증권 Open API App Key다. KIS 개발자 포털에서 발급받은 값을 넣는다.
KIS_APP_KEY=
# 한국투자증권 Open API App Secret이다. 절대 커밋하지 않는다.
KIS_APP_SECRET=
# KIS 접근토큰이다. 보통 비워두며, 서버가 App Key/Secret으로 자동 발급한다.
# 재시작 직후 KIS의 1분당 토큰 발급 제한을 피하고 싶을 때만 임시 입력한다.
KIS_ACCESS_TOKEN=
# 한국투자증권 계좌번호 앞 8자리다. 모의/실전 계좌에 맞게 입력한다.
KIS_ACCOUNT_NO=
# 한국투자증권 계좌번호 뒤 2자리 상품코드다.
KIS_ACCOUNT_PRODUCT_CODE=
# true면 KIS 모의투자 서버, false면 KIS 실전 서버를 사용한다.
KIS_IS_PAPER=true
# KIS REST API 기본 주소다. 모의투자는 openapivts, 실전은 openapi 주소를 사용한다.
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
# KIS WebSocket 주소다. 실시간 시세/체결통보 확장 시 사용한다.
KIS_WS_URL=ws://ops.koreainvestment.com:31000
# KIS WebSocket 접속키다. 보통 비워두며, 서버가 /oauth2/Approval로 자동 발급해 로컬 캐시한다.
KIS_WS_APPROVAL_KEY=
# KIS WebSocket 접속키 로컬 캐시 파일 경로다. 비우면 .run/kis_ws_approval_cache.json을 사용한다.
KIS_WS_APPROVAL_CACHE_PATH=
# KIS 실시간 시세 WebSocket으로 동시에 구독할 최대 종목 수다.
KIS_REALTIME_MAX_SYMBOLS=20
# 전략/검색기 화면에서 KIS 현재가 스냅샷을 재사용할 최대 시간(분)이다. 0이면 조회 때마다 다시 받는다.
KIS_CURRENT_QUOTE_MAX_AGE_MINUTES=10
# 전략/검색기 화면 조회 시 KIS 현재가를 자동 갱신할 최대 후보 종목 수다.
KIS_CURRENT_QUOTE_REFRESH_MAX_SYMBOLS=30
# 전략/검색기 후보 계산용 일봉이 기대 거래일보다 이 값 이상 오래되면 지연 상태로 표시하고 갱신을 시도한다.
STRATEGY_DAILY_PRICE_MAX_STALENESS_DAYS=1

# Trading modes
# KIS 모의투자 주문 제출 허용 여부다. false면 조회는 되지만 주문 제출은 차단된다.
PAPER_TRADING_ENABLED=false
# KIS 실전투자 주문 제출 허용 여부다. 현재 실전 주문 기능은 미구현이므로 false를 유지한다.
LIVE_TRADING_ENABLED=false
# true면 모의/실전 주문 제출을 모두 즉시 차단한다. 긴급 중지나 수동 점검 중에 사용한다.
EMERGENCY_STOP_ENABLED=false
# true면 주문 제출 시 확인 문구 입력을 요구한다. 주문 테스트가 끝나기 전에는 true를 유지한다.
MANUAL_ORDER_CONFIRMATION_REQUIRED=true
# true면 주문 제출 직전에 KIS 잔고의 전일 대비 자산 감소액을 확인해 일일 손실 한도를 넘는 주문을 막는다.
DAILY_LOSS_STOP_ENABLED=false
# 1건 주문의 최대 예상금액이다. 종목별 주문금액이 이 값을 넘으면 주문을 막는다.
MAX_ORDER_AMOUNT_KRW=5000000
# 한국시간 기준 하루에 허용할 모의주문 제출 건수다. 일괄 주문은 종목 수만큼 계산한다.
MAX_DAILY_ORDER_COUNT=10
# 하루 최대 손실 중지 한도다. DAILY_LOSS_STOP_ENABLED=true일 때 주문 제출 직전에 검사한다.
MAX_DAILY_LOSS_KRW=50000

# Market data
# 기본 시장 지역이다. 현재는 한국 주식 중심이라 KR을 사용한다.
MARKET_REGION=KR
# 일봉 가격 데이터를 읽을 때 우선 적용할 제공처 순서다. KRX 승인 후에도 값만 바꾸면 된다.
DAILY_PRICE_PROVIDER_PRIORITY=KRX Open API,KIS Open API,Yahoo Finance
# KIS/Yahoo/KRX 호출에서 429/5xx 또는 일시 네트워크 오류가 날 때 재시도할 횟수다.
MARKET_DATA_RETRY_COUNT=2
# 재시도 사이에 기다릴 기본 시간(초)이다. 재시도 횟수에 따라 점진적으로 늘어난다.
MARKET_DATA_RETRY_BACKOFF_SECONDS=0.6
# KIS API 호출 사이 최소 간격(초)이다. 호출 제한 완화를 위해 사용한다.
KIS_REQUEST_MIN_INTERVAL_SECONDS=0.08
# Yahoo 데이터 호출 사이 최소 간격(초)이다.
YAHOO_REQUEST_MIN_INTERVAL_SECONDS=0.2
# KRX Open API 호출 사이 최소 간격(초)이다.
KRX_REQUEST_MIN_INTERVAL_SECONDS=0.2
# KRX 일봉은 일자별 전체 시장 API를 반복 호출하므로, 한 번에 조회할 최대 날짜 수를 제한한다.
KRX_DAILY_PRICE_MAX_DAYS=370
# 기본으로 다룰 한국 시장 목록이다.
DEFAULT_MARKET=KOSPI,KOSDAQ
# 데이터 일괄 적재 시 한 번에 처리할 최대 종목 수다.
DATA_IMPORT_BATCH_SIZE=50
# 데이터 적재 작업의 초당 호출 제한 기준이다.
DATA_IMPORT_RATE_LIMIT_PER_SECOND=1
# KRX Open API 인증키다. 요청 헤더 AUTH_KEY에 담아 호출한다.
KRX_OPEN_API_AUTH_KEY=
# KRX Open API 기본 주소다. KRX 제공 주소가 바뀔 때만 수정한다.
KRX_OPEN_API_BASE_URL=https://data-dbg.krx.co.kr/svc/apis/sto
# OpenDART 공시/재무제표 API 키다. 재무 상세 조건 확장 시 사용한다.
OPEN_DART_API_KEY=
# OpenDART API 기본 주소다. OpenDART 제공 주소가 바뀔 때만 수정한다.
OPEN_DART_BASE_URL=https://opendart.fss.or.kr/api
# OpenDART 고유번호 캐시 파일 경로다. 비우면 .run/opendart_corp_codes.json을 사용한다.
OPEN_DART_CORP_CODE_CACHE_PATH=
# OpenDART API 호출 사이 최소 간격(초)이다.
OPENDART_REQUEST_MIN_INTERVAL_SECONDS=0.2
